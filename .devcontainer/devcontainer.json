{
  "name": "archivist-ai",
  "dockerComposeFile": "compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {
      "dangerouslySkipPermissions": true
    }
  },
  "postCreateCommand": "npm config set prefix ~/.npm-global && uv sync --directory packages/archivist-cli && npm install --prefix packages/referentiel-cli",
  "postStartCommand": "npm install -g @anthropic-ai/claude-code@latest 2>&1 | tail -1",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.npm-global/bin"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/packages/archivist-cli/.venv/bin/python",
        "editor.formatOnSave": true
      }
    }
  }
}
