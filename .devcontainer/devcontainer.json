{
  "name": "archivist-ai",
  "dockerComposeFile": "compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {
      "dangerouslySkipPermissions": true
    }
  },
  "postCreateCommand": "uv sync --directory packages/archivist-cli && npm install --prefix packages/referentiel-cli",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/packages/archivist-cli/.venv/bin/python",
        "editor.formatOnSave": true
      }
    }
  }
}
