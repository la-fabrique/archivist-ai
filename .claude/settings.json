{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000",
    "OTEL_LOGS_EXPORT_INTERVAL": "5000"
  },
  "permissions": {
    "allow": [
      "Read(/workspace/**)",
      "Read(/workspace/.claude/worktrees/**)",
      "Edit(/workspace/**)",
      "Edit(/workspace/.claude/worktrees/**)",
      "Write(/workspace/**)",      
      "Write(/workspace/.claude/worktrees/**)",
      "Bash(xargs cat:*)",     
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(uv *)",
      "Bash(echo *)",
      "Bash(grep *)", 
      "Bash(cd *)",
      "Bash(uv *)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit *)",      
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git -C *)",
      "Bash(git reset *)",
      "Bash(git worktree *)",
      "Bash(git push *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(npm install *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(python3 *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(curl *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Edit(.github/workflows/*)",
      "Write(.github/workflows/*)"      
    ],
    "defaultMode": "dontAsk"
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo /workspace)\" && .claude/hooks/referentiel-guard.sh'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo /workspace)\" && .claude/hooks/no-commit-on-main.sh'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo /workspace)\" && .claude/hooks/commit-lint.sh'"
          },
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo /workspace)\" && .claude/hooks/feat-commit-cleanup.sh'"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo /workspace)\" && .harness/scripts/skill-trace.sh'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo /workspace)\" && .harness/scripts/session-start.sh'",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null)\" && .claude/hooks/dev-cycle-reminder.sh'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "printf '\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m' \"$(whoami)\" \"$(hostname -s)\" \"$(pwd)\""
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@superpowers-dev": true,
    "pm-product-strategy@pm-skills": true,
    "pm-ai-shipping@pm-skills": true
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    },
    "pm-skills": {
      "source": {
        "source": "github",
        "repo": "phuryn/pm-skills"
      }
    }
  },
  "effortLevel": "medium",
  "advisorModel": "claude-opus-4-8"
}
