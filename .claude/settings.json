{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000",
    "OTEL_LOGS_EXPORT_INTERVAL": "5000"
  },
  "permissions": {
    "allow": [
      "Bash(xargs cat:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Bash(git commit *)",
      "Edit(/.claude/skills/**)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(npx vitest *)",
      "Bash(npx tsc *)",
      "Bash(git -C *)",
      "Bash(git commit -m ' *)",
      "Bash(git reset *)",
      "Bash(curl *)",
      "Bash(git worktree *)",
      "Bash(npm install *)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/deka/sources/github/archivist-ai/.claude/hooks/referentiel-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/deka/sources/github/archivist-ai/.claude/hooks/no-commit-on-main.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/deka/sources/github/archivist-ai/.claude/hooks/commit-lint.sh"
          },
          {
            "type": "command",
            "command": "/home/deka/sources/github/archivist-ai/.claude/hooks/feat-commit-cleanup.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".harness/scripts/session-start.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/dev-cycle-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "printf '\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m' \"$(whoami)\" \"$(hostname -s)\" \"$(pwd)\""
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@superpowers-dev": true
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    }
  },
  "effortLevel": "medium",
  "advisorModel": "claude-opus-4-6"
}
